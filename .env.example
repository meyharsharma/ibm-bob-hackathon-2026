# IBM Watson/Bob Configuration
IBM_WATSON_API_KEY=your_api_key_here
IBM_WATSON_URL=https://api.us-south.assistant.watson.cloud.ibm.com
IBM_WATSON_ASSISTANT_ID=your_assistant_id_here

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Repository Configuration
MAX_COMMITS=10000
MAX_FILES=5000
DEFAULT_PLAYBACK_DURATION=90

# Logging
LOG_LEVEL=INFO
LOG_FILE=time_machine.log

# Cache Configuration
ENABLE_CACHE=True
CACHE_DIR=data/cache

# Narration Configuration
NARRATION_DIR=data/narration
ENABLE_OFFLINE_MODE=False